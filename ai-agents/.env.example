PORT=3500

# GitHub Models uses GitHub personal access tokens.
# Keep real values in .env only; do not commit them.
GITHUB_AGENT_1_KEY=ghp_replace_agent_1
GITHUB_AGENT_2_KEY=ghp_replace_agent_2
GITHUB_AGENT_3_KEY=ghp_replace_agent_3
GITHUB_AGENT_4_KEY=ghp_replace_agent_4

GITHUB_MODELS_ENDPOINT=https://models.github.ai/inference/chat/completions
GITHUB_MODELS_MODEL=openai/gpt-4o-mini
GITHUB_API_VERSION=2026-03-10
ORCHESTRATION_BRIDGE_URL=http://localhost:3400

# Production values are 3600000 and 600000.
# Lower these locally when you want to test a full cycle quickly.
PLAY_SESSION_MS=3600000
REFLECTION_SESSION_MS=600000
